# =========================================
# Production environment
# =========================================
NODE_ENV=production

# Public URL of the deployed site (used for canonical, OG, sitemap)
NEXT_PUBLIC_SITE_URL=https://baz.agency

# Booking URL (Cal.com, Calendly, etc.)
NEXT_PUBLIC_BOOKING_URL=https://cal.com/baz/growth-call

# Real brand stats — only set if you have verified numbers.
# Empty/null = stat hidden on the homepage.
NEXT_PUBLIC_BRANDS_SCALED=
NEXT_PUBLIC_COUNTRIES_SERVED=
NEXT_PUBLIC_TEAM_SIZE=
NEXT_PUBLIC_SENIOR_ONLY=100%

# =========================================
# Lead pipeline
# =========================================

# Resend (https://resend.com) for email notification on new lead.
# Leave empty to disable — leads still persist to /app/data/leads.jsonl.
RESEND_API_KEY=
NOTIFY_EMAIL=zerboutbrahimamir@gmail.com
NOTIFY_FROM=BAZ Site <noreply@baz.agency>

# Webhook fallback (Slack, HubSpot, Pipedrive, Zapier, etc.)
LEAD_INTAKE_URL=
LEAD_INTAKE_TOKEN=

# Admin token — required to enable /admin/leads and /api/leads GET.
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
ADMIN_TOKEN=

# =========================================
# Analytics
# =========================================
# Google Analytics 4 property ID
NEXT_PUBLIC_GA4_ID=